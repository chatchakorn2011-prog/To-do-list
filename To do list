<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>แจ้งเตือนงาน</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#f5f5f5;
display:flex;
justify-content:center;
padding:25px;
}

.container{
width:100%;
max-width:420px;
background:white;
border-radius:20px;
padding:20px;
box-shadow:0 10px 30px rgba(0,0,0,.1);
}

h1{
text-align:center;
margin-bottom:20px;
font-size:28px;
}

.input-box{
display:flex;
gap:10px;
margin-bottom:20px;
}

input{
flex:1;
padding:12px;
border:none;
background:#eee;
border-radius:12px;
font-size:16px;
}

button{
padding:12px 18px;
border:none;
background:#000;
color:white;
border-radius:12px;
font-size:16px;
cursor:pointer;
}

button:hover{
opacity:.8;
}

.task{
display:flex;
justify-content:space-between;
align-items:center;
background:#fafafa;
padding:15px;
border-radius:15px;
margin-bottom:10px;
animation:show .3s;
}

.task span{
font-size:16px;
}

.delete{
background:red;
padding:8px 12px;
border-radius:10px;
color:white;
cursor:pointer;
}

@keyframes show{
from{
opacity:0;
transform:translateY(15px);
}
to{
opacity:1;
transform:translateY(0);
}
}
</style>

</head>
<body>

<div class="container">

<h1>📋 งานของฉัน</h1>

<div class="input-box">
<input id="task" placeholder="เพิ่มงาน...">
<button onclick="addTask()">เพิ่ม</button>
</div>

<div id="list"></div>

</div>

<script>

let tasks=JSON.parse(localStorage.getItem("tasks"))||[];

show();

function addTask(){

let input=document.getElementById("task");

if(input.value=="") return;

tasks.push(input.value);

localStorage.setItem("tasks",JSON.stringify(tasks));

input.value="";

show();

}

function del(i){

tasks.splice(i,1);

localStorage.setItem("tasks",JSON.stringify(tasks));

show();

}

function show(){

let html="";

tasks.forEach((t,i)=>{

html+=`
<div class="task">
<span>${t}</span>
<div class="delete" onclick="del(${i})">ลบ</div>
</div>
`;

});

document.getElementById("list").innerHTML=html;

}

setInterval(()=>{

if(tasks.length>0){

new Notification("📌 อย่าลืมทำงานนะ!");

}

},60000);

Notification.requestPermission();

</script>

</body>
</html>
